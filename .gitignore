# ==========================================
# .gitignore - ملف تجاهل الملفات غير المهمة
# ==========================================

# Node modules
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Build output
dist/
build/
*.min.js
*.min.css

# IDE settings
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment files
.env
.env.local
.env.*.local

# OS files
Thumbs.db
.DS_Store

# Temporary files
*.tmp
*.temp
*.bak

# Logs
logs/
*.log

# Package manager locks (optional)
# Uncomment if you want to commit lock files
# package-lock.json
# yarn.lock
