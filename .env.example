# ==========================================
# ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in your actual values
# ==========================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard
# URL format: https://[project-id].supabase.co
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_ACTUAL_KEY_HERE

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration (comma-separated list of allowed origins)
# For development: localhost URLs
# For production: your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# API Configuration
API_TIMEOUT=10000
API_MAX_RETRIES=3

# Frontend Environment Variables (used during build)
# These are accessed via process.env.REACT_APP_*
REACT_APP_BACKEND_URL=http://localhost:3000
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
REACT_APP_SUPABASE_KEY=sb_publishable_YOUR_ACTUAL_KEY_HERE
REACT_APP_API_TIMEOUT=10000
